{
  "manifest_version": 3,
  "name": "Workday - Schedule Tool",
  "version": "1.0",
  "description": "Extract your registered courses from the Workday View My Courses page.",

  "permissions": ["storage"],

  "host_permissions": ["https://*.myworkday.com/*"],

  "action": {
    "default_title": "Workday Course Extractor",
    "default_icon": {
      "16": "dist/workday-extention-logo.svg",
      "48": "dist/workday-extention-logo.svg",
      "128": "dist/workday-extention-logo.svg"
    }
  },

  "background": {
    "service_worker": "dist/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*.myworkday.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["dist/css/*.css", "dist/panel.html", "dist/W.svg", "dist/workday-extention-logo.svg"],
      "matches": ["https://*.myworkday.com/*"]
    }
  ]
}
