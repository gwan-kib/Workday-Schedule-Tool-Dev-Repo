{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022", "WebWorker"],
    "types": ["chrome", "vite/client"]
  },
  "include": [
    "entrypoints",
    "src",
    "tests",
    "wxt.config.ts",
    "eslint.config.mjs",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
