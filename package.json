{
  "name": "ubc-workday-schedule-tool",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "description": "A Chrome extension that helps students visualize, compare, and export Workday schedules.",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwan-kib/Workday-Extension.git"
  },
  "keywords": [
    "chrome-extension",
    "wxt",
    "react",
    "typescript",
    "workday"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gwan-kib/Workday-Extension/issues"
  },
  "homepage": "https://github.com/gwan-kib/Workday-Extension#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@types/chrome": "^0.1.13",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^4.0.0",
    "wxt": "^0.20.20"
  }
}
